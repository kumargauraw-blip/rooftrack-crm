PORT=3001
JWT_SECRET=super-secret-roof-key-123
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DATABASE_PATH=./rooftrack.db

# --- Email (SendLayer) ---
# Required for manual campaigns AND the new-lead autoresponder.
# Every email the CRM sends is automatically BCC'd to CRM_BCC_EMAIL.
SENDLAYER_API_KEY=
SENDLAYER_FROM_EMAIL=website@honestroof.com
SENDLAYER_FROM_NAME=HonestRoof.com
CRM_BCC_EMAIL=dennis@honestroof.com

# --- Trusted internal caller secret ---
# The honestroof.com Next.js site sends this as `X-Internal-Key` on
# server-to-server lead submissions so the CRM skips rate limiting
# and the honeypot check. Generate with:
#   openssl rand -hex 32
# Must match NEXT_PUBLIC_* … NO — must match CRM_INTERNAL_API_KEY on the site.
CRM_INTERNAL_API_KEY=
