PORT=3001
JWT_SECRET=super-secret-roof-key-123
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DATABASE_PATH=./rooftrack.db

# --- Email (SendLayer) ---
# Required for manual campaigns AND the new-lead autoresponder.
# Every email the CRM sends is automatically BCC'd to CRM_BCC_EMAIL.
SENDLAYER_API_KEY=
SENDLAYER_FROM_EMAIL=website@honestroof.com
SENDLAYER_FROM_NAME=HonestRoof.com
CRM_BCC_EMAIL=dennis@honestroof.com

# --- Trusted internal caller secret ---
# The honestroof.com Next.js site sends this as `X-Internal-Key` on
# server-to-server lead submissions so the CRM skips rate limiting
# and the honeypot check. Generate with:
#   openssl rand -hex 32
# Must match NEXT_PUBLIC_* … NO — must match CRM_INTERNAL_API_KEY on the site.
CRM_INTERNAL_API_KEY=

# --- Retell voice + SMS ---
# RETELL_API_KEY: from Retell dashboard. Used both for webhook signature
# verification (the voice agent signs call_analyzed events with this key)
# and as the Bearer token for outbound calls to api.retellai.com (the
# Twilio SMS bridge uses this to drive the chat agent).
RETELL_API_KEY=
# The Rufus voice agent id - if a call_analyzed event comes in from a
# different agent the webhook drops it.
RETELL_AGENT_ID=
# The Rufus SMS chat agent id - separate resource, created via
# /create-chat-agent. The SMS bridge starts chats against this agent.
RETELL_SMS_AGENT_ID=

# --- Twilio (inbound SMS bridge + outbound replies) ---
# From the Twilio console homepage. Both values are sensitive.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The E.164 number we send SMS replies FROM. Must match the inbound
# number the customer texted, or carriers will reject the reply.
TWILIO_FROM_NUMBER=+18178097000
